APP_NAME=LeetRace API
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=300
DB_USE_NULL_POOL_FOR_SUPABASE_POOLER=true
LEETCODE_API_BASE_URL=https://leetcode-api-pied.vercel.app
APP_TOKEN_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
FRONTEND_BASE_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
LEETCODE_VERIFICATION_MODE=soft
SYNC_INTERVAL_SECONDS=15
AUTO_SOLVE_SYNC_ENABLED=false
AVATAR_SYNC_TTL_SECONDS=21600
MAX_PARTICIPANTS_PER_ROOM=50
ADMIN_BOOTSTRAP_USER_IDS=
ADMIN_BOOTSTRAP_EMAILS=
