APP_NAME=LeetCode Room Race API
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
LEETCODE_API_BASE_URL=https://leetcode-api-pied.vercel.app
APP_TOKEN_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000
